generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("TECH")
  passwordHash  String
  emailVerified DateTime?
  image         String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  accounts      Account[]
  sessions      Session[]
}

model Staff {
  id            String       @id @default(cuid())
  firstName     String?
  lastName      String?
  staffCode     String       @unique
  departmentId  String?
  designationId String?
  Asset         Asset[]
  department    Department?  @relation(fields: [departmentId], references: [id])
  designation   Designation? @relation(fields: [designationId], references: [id])
  attendedTasks TaskLog[]    @relation("AttendedBy")
  approvedTasks TaskLog[]    @relation("ApprovedBy")
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model Outlet {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tasks     TaskLog[]
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  assets    Asset[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique
  code      String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id           String        @id @default(cuid())
  tag          String        @unique
  category     String
  model        String
  serialNumber String?
  quantity     Int           @default(1)
  status       String
  brandId      String?
  locationId   String?
  staffId      String?
  departmentId String?
  pcHostname   String?
  employeeName String?
  designation  String?
  processor    String?
  ram          String?
  hdd          String?
  os           String?
  serviceTag   String?
  ipAddress    String?
  assignee     String?
  createdAt    DateTime      @default(now())
  updatedAt    DateTime      @updatedAt
  brand        Brand?        @relation(fields: [brandId], references: [id])
  location     Location?     @relation(fields: [locationId], references: [id])
  staff        Staff?        @relation(fields: [staffId], references: [id])
  department   Department?   @relation(fields: [departmentId], references: [id])
  customValues CustomValue[]
}

model CategoryCounter {
  category String @id
  counter  Int    @default(0)
}

model Status {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  TaskLog   TaskLog[]
}

model CustomField {
  id        String        @id @default(cuid())
  name      String
  type      String
  category  String
  createdAt DateTime      @default(now())
  values    CustomValue[]

  @@unique([name, category])
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  assets    Asset[]
  staff     Staff[]
  TaskLog   TaskLog[]
}

model Designation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  staff     Staff[]
}

model CustomValue {
  id      String      @id @default(cuid())
  assetId String
  fieldId String
  value   String?
  asset   Asset       @relation(fields: [assetId], references: [id])
  field   CustomField @relation(fields: [fieldId], references: [id])

  @@unique([assetId, fieldId])
}

model Log {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String
  actorEmail String?
  details    String?
  createdAt  DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?
  user               User    @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime
  user         User     @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tasks     TaskLog[]
}

model IssueType {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  tasks     TaskLog[]
}

model TaskLog {
  id             String      @id @default(cuid())
  date           DateTime    @default(now())
  roomId         String?
  departmentId   String?
  outletId       String?
  issueTypeId    String?
  issueCategory  String      @default("TroubleShoot")
  statusId       String
  attendedById   String?
  approvedById   String?
  approvedDate   DateTime?
  detail         String
  actionTaken    String?
  createdByEmail String?
  closedDate     DateTime?
  room           Room?       @relation(fields: [roomId], references: [id])
  department     Department? @relation(fields: [departmentId], references: [id])
  outlet         Outlet?     @relation(fields: [outletId], references: [id])
  issueType      IssueType?  @relation(fields: [issueTypeId], references: [id])
  status         Status      @relation(fields: [statusId], references: [id])
  attendedBy     Staff?      @relation("AttendedBy", fields: [attendedById], references: [id])
  approvedBy     Staff?      @relation("ApprovedBy", fields: [approvedById], references: [id])

  @@index([date])
  @@index([statusId])
}

model InventoryItem {
  id         String   @id @default(cuid())
  name       String   @unique
  details    String?
  assigned   Int      @default(0)
  unassigned Int      @default(0)
  damaged    Int      @default(0)
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  action     String
  category   String?
  entity     String?
  message    String?
  actorEmail String?
  actorName  String?
  ip         String?
  before     String?
  after      String?
}

model UserActivity {
  id        String   @id @default(cuid())
  userId    String
  userEmail String
  userName  String?
  action    String
  ipAddress String?
  userAgent String?
  sessionId String?
  createdAt DateTime @default(now())

  @@index([userId, createdAt])
  @@index([createdAt])
}

model Model {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model NetworkDevice {
  id            String   @id @default(cuid())
  type          String
  switchName    String?
  mac           String?
  serialNo      String?
  port          String?
  uplink        String?
  sfpCoreSwPort String?
  ipAddress     String?
  password      String?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model OntZone {
  id        String   @id @default(cuid())
  room      String
  fsanNo    String
  mac       String
  serialNo  String
  zone      String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
