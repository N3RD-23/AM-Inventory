generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  role          String    @default("TECH") // ADMIN | TECH
  passwordHash  String
  emailVerified DateTime?
  image         String?

  accounts Account[]
  sessions Session[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Staff {
  id            String       @id @default(cuid())
  firstName     String?
  lastName      String?
  staffCode     String       @unique
  departmentId  String?
  department    Department?  @relation(fields: [departmentId], references: [id], onDelete: SetNull)
  designationId String?
  designation   Designation? @relation(fields: [designationId], references: [id], onDelete: SetNull)

  attendedTasks TaskLog[] @relation("AttendedBy")
  approvedTasks TaskLog[] @relation("ApprovedBy")
  Asset         Asset[]
}

model Location {
  id        String   @id @default(cuid())
  name      String   @unique
  address   String?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[]
}

model Outlet {
  id        String    @id @default(cuid())
  name      String    @unique
  tasks     TaskLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model Brand {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  assets Asset[]
}

model Category {
  id        String   @id @default(cuid())
  name      String   @unique // what users select (e.g., "PC", "MONITOR", "UPS")
  code      String? // optional short code used in tags (e.g., "PC", "MON", "UPS")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model Asset {
  id           String  @id @default(cuid())
  tag          String  @unique
  category     String
  model        String
  serialNumber String?
  quantity     Int     @default(1)
  status       String

  brandId    String?
  brand      Brand?    @relation(fields: [brandId], references: [id])
  locationId String?
  location   Location? @relation(fields: [locationId], references: [id])

  staffId String?
  staff   Staff?  @relation(fields: [staffId], references: [id])

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id])

  pcHostname   String? // used by UPS/MONITOR and PC (Hostname)
  employeeName String? // UPS/MONITOR
  designation  String? // UPS/MONITOR

  processor  String?
  ram        String? // string to allow e.g. "16 GB"
  hdd        String? // allow "512 GB SSD", etc.
  os         String?
  serviceTag String?
  ipAddress  String?

  assignee String?

  customValues CustomValue[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

model CategoryCounter {
  category String @id
  counter  Int    @default(0)
}

model Status {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  TaskLog   TaskLog[]
}

model CustomField {
  id        String   @id @default(cuid())
  name      String
  type      String // text | number | date
  category  String // MONITOR | PC | UPS
  createdAt DateTime @default(now())

  values CustomValue[]

  @@unique([name, category])
}

model Department {
  id        String    @id @default(cuid())
  name      String    @unique
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
  assets    Asset[]
  staff     Staff[]
  TaskLog   TaskLog[]
}

model Designation {
  id        String   @id @default(cuid())
  name      String   @unique
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  staff Staff[] // reverse relation
}

model CustomValue {
  id      String  @id @default(cuid())
  assetId String
  fieldId String
  value   String?

  asset Asset       @relation(fields: [assetId], references: [id])
  field CustomField @relation(fields: [fieldId], references: [id])

  @@unique([assetId, fieldId])
}

model Log {
  id         String   @id @default(cuid())
  action     String
  entity     String
  entityId   String
  actorEmail String?
  details    String?
  createdAt  DateTime @default(now())
}

model Account {
  id                 String  @id @default(cuid())
  userId             String
  type               String
  provider           String
  providerAccountId  String
  refresh_token      String?
  access_token       String?
  expires_at         Int?
  token_type         String?
  scope              String?
  id_token           String?
  session_state      String?
  oauth_token_secret String?
  oauth_token        String?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([provider, providerAccountId])
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

model Room {
  id        String    @id @default(cuid())
  name      String    @unique
  tasks     TaskLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model IssueType {
  id        String    @id @default(cuid())
  name      String    @unique
  tasks     TaskLog[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt
}

model TaskLog {
  id   String   @id @default(cuid())
  date DateTime @default(now())

  roomId String?
  room   Room?   @relation(fields: [roomId], references: [id], onDelete: SetNull)

  departmentId String?
  department   Department? @relation(fields: [departmentId], references: [id], onDelete: SetNull)

  outletId String?
  outlet   Outlet? @relation(fields: [outletId], references: [id], onDelete: SetNull)

  issueTypeId String?
  issueType   IssueType? @relation(fields: [issueTypeId], references: [id], onDelete: SetNull)

  issueCategory String @default("TroubleShoot")

  statusId String
  status   Status @relation(fields: [statusId], references: [id])

  attendedById String?
  attendedBy   Staff?  @relation("AttendedBy", fields: [attendedById], references: [id], onDelete: SetNull)

  closedDate DateTime?

  approvedById String?
  approvedBy   Staff?    @relation("ApprovedBy", fields: [approvedById], references: [id], onDelete: SetNull)
  approvedDate DateTime?

  detail      String
  actionTaken String?

  createdByEmail String?

  @@index([date])
  @@index([statusId])
}

model InventoryItem {
  id         String   @id @default(cuid())
  name       String   @unique
  details    String?
  assigned   Int      @default(0) // assigned out in the field
  unassigned Int      @default(0) // in stock (available)
  damaged    Int      @default(0) // damaged/unusable
  createdAt  DateTime @default(now())
  updatedAt  DateTime @updatedAt
}

model AuditLog {
  id         String   @id @default(cuid())
  createdAt  DateTime @default(now())
  action     String
  category   String?
  entity     String?
  message    String?
  actorEmail String?
  actorName  String?
  ip         String?
  before     String? // JSON serialized, or use Json if supported
  after      String? // JSON serialized, or use Json if supported
  // @@index([createdAt, action, category])
}
